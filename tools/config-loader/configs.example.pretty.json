{
  "api.soapbucket.com": {
    "hostname": "api.soapbucket.com",
    "type": "proxy",
    "config": {
      "url": "https://news.ycombinator.com",
      "timeout": "30s",
      "maxConnections": 100,
      "rateLimit": 1000,
      "burstLimit": 2000,
      "flushInterval": "100ms",
      "idleConnTimeout": "90s",
      "tlsHandshakeTimeout": "10s",
      "dialTimeout": "30s",
      "keepAlive": "30s"
    }
  },
  "api.soapbucket.com:8443": {
    "hostname": "api.soapbucket.com:8443",
    "type": "proxy",
    "forwardHostname": "api.soapbucket.com",
    "config": {
      "url": "https://api.soapbucket.com",
      "timeout": "60s"
    }
  },
  "localhost:8443": {
    "hostname": "localhost:8443",
    "type": "proxy",
    "config": {
      "url": "https://example.com",
      "timeout": "30s",
      "maxConnections": 50,
      "flushInterval": "100ms"
    }
  },
  "secure.example.com": {
    "hostname": "secure.example.com",
    "type": "proxy",
    "forceSSL": true,
    "config": {
      "url": "https://backend.example.com",
      "timeout": "30s",
      "maxConnections": 100
    }
  }
}

