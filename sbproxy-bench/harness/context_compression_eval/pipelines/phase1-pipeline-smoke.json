{
  "schema_version": 1,
  "profile": "phase1-pipeline-smoke-v1",
  "levers": [
    {
      "type": "rag_select",
      "min_tokens": 1,
      "ranking": "supplied",
      "max_chunks": 3,
      "min_relevance_percent": 20,
      "drop_empty": false
    },
    {
      "type": "compact_serialization",
      "min_tokens": 1,
      "tabular": {
        "enabled": true,
        "min_rows": 20
      }
    },
    {
      "type": "position_reorder",
      "ranking": "supplied"
    },
    {
      "type": "window_fit",
      "completion_reserve_tokens": 8000,
      "input_budget_tokens": 512
    }
  ]
}
