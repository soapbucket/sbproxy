  "id": null,
  "uid": "sbproxy-ai-gateway",
  "title": "SBProxy AI Gateway",
  "description": "AI gateway metrics including provider performance, token usage, guardrails, and fallbacks.",
  "tags": [
    "sbproxy",
    "ai-gateway"
  ],
  "style": "dark",
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "refresh": "10s",
  "version": 1,
  "schemaVersion": 39,
  "panels": [
    {
      "id": 1,
      "title": "AI Requests/sec by Provider",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "spanNulls": false,
            "drawStyle": "line",
            "pointSize": 5,
            "showPoints": "auto"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (provider) (rate(sbproxy_ai_requests_attributed_total[5m]))",
          "legendFormat": "{{provider}}",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ],
      "description": "Measures AI Requests/sec by Provider. Runbook: docs/operator-runbook.md#ai-gateway. When red, inspect the matching component, confirm healthy range, and follow the rollback guidance if the spike follows a config change."
    },
    {
      "id": 2,
      "title": "Token Usage (Input / Output)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
