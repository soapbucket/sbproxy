        "uid": "${DS_PROMETHEUS}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "spanNulls": false,
            "drawStyle": "line",
            "pointSize": 5,
            "showPoints": "auto"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (provider) (rate(sbproxy_ai_tokens_attributed_total{direction=\"input\"}[5m]))",
          "legendFormat": "Input - {{provider}}",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        },
        {
          "refId": "B",
          "expr": "sum by (provider) (rate(sbproxy_ai_tokens_attributed_total{direction=\"output\"}[5m]))",
          "legendFormat": "Output - {{provider}}",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
