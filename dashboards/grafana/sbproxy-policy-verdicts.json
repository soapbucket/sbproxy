{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "10.0.0"
    },
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": "1.0.0"
    },
    {
      "type": "panel",
      "id": "timeseries",
      "name": "Time series",
      "version": ""
    }
  ],
  "id": null,
  "uid": "sbproxy-policy-verdicts",
  "title": "SBProxy Policy Verdicts",
  "description": "Policy decision audit telemetry: verdict rate by tag, plugin vs built-in surface ratio, audit bus drops, and decision latency percentiles. Sourced from the WOR-201 PR 1b bus and metric wiring.",
  "tags": [
    "sbproxy",
    "policy",
    "audit"
  ],
  "style": "dark",
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "refresh": "10s",
  "version": 1,
  "schemaVersion": 39,
  "panels": [
    {
      "id": 1,
      "title": "Verdict Rate by Tag",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "spanNulls": false,
            "drawStyle": "line",
            "pointSize": 5,
            "showPoints": "auto"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (verdict) (rate(sbproxy_policy_audit_events_total[5m]))",
          "legendFormat": "{{verdict}}",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ],
      "description": "Per-second rate of policy decisions emitted on the audit bus, broken down by verdict tag (allow / deny / confirm / allow_with_headers). Sustained spikes in deny or confirm signal a misconfigured policy or unexpected traffic shift; cross-reference with the per-policy panel below."
    },
    {
      "id": 2,
      "title": "Audit Events Dropped per Tenant",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "spanNulls": false,
            "drawStyle": "line",
            "pointSize": 5,
            "showPoints": "auto"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Audit dropped"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "red",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (tenant) (rate(sbproxy_policy_audit_events_dropped_total[5m]))",
          "legendFormat": "{{tenant}}",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ],
      "description": "Rate of policy verdict events dropped because the in-memory audit bus was full. Per `docs/adr-policy-audit-binding.md` this is a paging signal: a non-zero rate means the audit consumer is offline or saturated and decisions are slipping through unrecorded. Page on a sustained non-zero value."
    },
    {
      "id": 3,
      "title": "Plugin vs Built-In Surface",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "spanNulls": false,
            "drawStyle": "line",
            "pointSize": 5,
            "showPoints": "auto"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (surface) (rate(sbproxy_policy_audit_events_total[5m]))",
          "legendFormat": "{{surface}}",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ],
      "description": "Decisions per second, split by the surface that produced them: `built_in` for the 21 enum-arm policies and `plugin` for dynamic-dispatch `PolicyEnforcer` impls. Most OSS deployments will see all traffic on `built_in` until PR 1c lands."
    },
    {
      "id": 4,
      "title": "Decision Latency P50 / P95 / P99",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "spanNulls": false,
            "drawStyle": "line",
            "pointSize": 5,
            "showPoints": "auto"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.5, sum by (le, surface) (rate(sbproxy_policy_decision_duration_seconds_bucket[5m])))",
          "legendFormat": "P50 - {{surface}}",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.95, sum by (le, surface) (rate(sbproxy_policy_decision_duration_seconds_bucket[5m])))",
          "legendFormat": "P95 - {{surface}}",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        },
        {
          "refId": "C",
          "expr": "histogram_quantile(0.99, sum by (le, surface) (rate(sbproxy_policy_decision_duration_seconds_bucket[5m])))",
          "legendFormat": "P99 - {{surface}}",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ],
      "description": "Wall-clock latency of policy decisions, broken down by surface. Built-in arms typically land sub-millisecond; plugin enforcers can reach tens of milliseconds when they make a network call. Tail latency on `plugin` deserves attention because the dispatcher is fully synchronous."
    },
    {
      "id": 5,
      "title": "Top Policies by Verdict Rate",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 16
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "spanNulls": false,
            "drawStyle": "line",
            "pointSize": 5,
            "showPoints": "auto"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "topk(10, sum by (policy_id, verdict) (rate(sbproxy_policy_audit_events_total[5m])))",
          "legendFormat": "{{policy_id}} - {{verdict}}",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ],
      "description": "Top 10 (policy, verdict) tuples by 5-minute rate. Use this to spot a single policy dominating the deny path or a plugin returning Confirm on every request when it should not."
    },
    {
      "id": 6,
      "title": "semantic_constraint Verdicts",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 24
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "spanNulls": false,
            "drawStyle": "line",
            "pointSize": 5,
            "showPoints": "auto"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (verdict) (rate(sbproxy_policy_audit_events_total{policy_type=\"semantic_constraint\"}[5m]))",
          "legendFormat": "{{verdict}}",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ],
      "description": "WOR-203 PR 3b panel. Per-second verdict rate for the `semantic_constraint` policy. Pair with the SBProxy Judge Backend dashboard for the underlying judge call latency, cache hit rate, and budget telemetry. A non-zero deny rate here typically corresponds to deny verdicts in the judge dashboard's verdict panel."
    }
  ],
  "templating": {
    "list": []
  },
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  }
}
