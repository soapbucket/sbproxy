      "path": "/test/rate-limited",
      "method": "GET",
      "request": {},
      "response": {
        "status": 429,
        "headers": {
          "Content-Type": "application/json",
          "X-RateLimit-Limit": "100",
          "X-RateLimit-Remaining": "0",
          "Retry-After": "60"
        },
        "body": {
          "status": "error",
          "message": "Rate limit exceeded",
          "code": "RATE_LIMITED"
        }
      }
    },
    {
      "id": "large-payload",
