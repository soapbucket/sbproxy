{
  "name": "E2E Test Configuration",
  "description": "Standard test scenarios for proxy end-to-end testing",
  "defaults": {
    "status": 200,
    "headers": {
      "X-Test-Server": "e2e-test-server"
    }
  },
  "scenarios": [
    {
      "id": "simple-200",
      "name": "Simple 200 OK Response",
      "path": "/test/simple-200",
      "method": "GET",
      "request": {},
      "response": {
        "status": 200,
        "headers": {
          "Content-Type": "application/json",
          "X-Test-Scenario": "simple-200"
        },
        "body": {
          "status": "success",
          "message": "Simple test response",
          "test_id": "simple-200"
        }
      }
    },
    {
      "id": "auth-required",
      "name": "Authentication Required",
      "path": "/test/auth-required",
      "method": "GET",
      "request": {
        "headers": {
          "Authorization": "Bearer test-token"
        }
      },
      "response": {
        "status": 200,
        "headers": {
          "Content-Type": "application/json",
          "X-Auth-Validated": "true"
        },
        "body": {
          "status": "authenticated",
          "user": "test-user",
          "roles": ["user", "tester"]
        }
      }
    },
    {
      "id": "delayed-response",
      "name": "Delayed Response (500ms)",
      "path": "/test/delayed-response",
      "method": "GET",
      "request": {},
      "response": {
        "status": 200,
        "delay": 500,
        "headers": {
          "Content-Type": "application/json"
        },
        "body": {
          "status": "success",
          "delayed_ms": 500
        }
      }
    },
    {
      "id": "json-payload",
      "name": "JSON Payload Echo",
      "path": "/test/json-payload",
      "method": "POST",
      "request": {
        "headers": {
          "Content-Type": "application/json"
        },
        "body": {
          "test": "data"
        }
      },
      "response": {
        "status": 200,
        "headers": {
          "Content-Type": "application/json"
        },
        "body": {
          "status": "success",
          "received": true,
          "echo": "test data received"
        }
      }
    },
    {
      "id": "error-500",
      "name": "Internal Server Error",
      "path": "/test/error-500",
      "method": "GET",
      "request": {},
      "response": {
        "status": 500,
        "headers": {
          "Content-Type": "application/json"
        },
        "body": {
          "status": "error",
          "message": "Simulated internal server error",
          "code": "INTERNAL_ERROR"
        }
      }
    },
    {
      "id": "not-found",
      "name": "Not Found Error",
      "path": "/test/not-found",
      "method": "GET",
      "request": {},
      "response": {
        "status": 404,
        "headers": {
          "Content-Type": "application/json"
        },
        "body": {
          "status": "error",
          "message": "Resource not found",
          "code": "NOT_FOUND"
        }
