{
  "json-transform.test": {
    "id": "json-transform",
    "hostname": "json-transform.test",
    "action": {
      "type": "proxy",
      "url": "http://e2e-test-server:8090"
    },
    "transforms": [
      {
        "type": "json",
        "content_types": [
          "application/json"
        ],
        "pretty_print": true,
        "remove_empty_objects": true,
        "remove_empty_arrays": false,
        "rules": [
          {
            "path": "$.sensitive",
            "value": "REDACTED"
          }
        ]
      }
    ],
    "workspace_id": "test-tenant",
    "version": "1.0-test"
  }
}
