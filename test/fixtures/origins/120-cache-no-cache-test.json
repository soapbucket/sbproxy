{
  "cache-no-cache.test": {
    "id": "cache-no-cache",
    "hostname": "cache-no-cache.test",
    "cache_settings": {
      "disabled": false,
      "level": "l2",
      "ttl": "1m",
      "cache_control": {
        "respect_cache_control": true,
        "respect_no_cache": true
      }
    },
    "action": {
      "type": "proxy",
      "url": "http://e2e-test-server:8090/cache-test/no-cache"
    }
  }
}