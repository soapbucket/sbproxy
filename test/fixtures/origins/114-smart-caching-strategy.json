{
  "smart-cache.test": {
    "id": "smart-cache",
    "hostname": "smart-cache.test",
    "cache_settings": {
      "disabled": false,
      "level": "l2",
      "ttl": "5m",
      "stale_while_revalidate": "1m",
      "stale_if_error": "1d",
      "cache_control": {
        "respect_cache_control": true,
        "min_fresh": 10
      },
      "conditional_rules": [
        {
          "match": {
            "path": {
              "prefix": "/api/static"
            }
          },
          "ttl": "1h"
        },
        {
          "match": {
            "path": {
              "prefix": "/api/dynamic"
            }
          },
          "ttl": "1m"
        }
      ]
    },
    "action": {
      "type": "proxy",
      "url": "http://e2e-test-server:8090/cache-test/smart"
    }
  }
}