{
  "html-transform.test": {
    "id": "html-transform",
    "hostname": "html-transform.test",
    "action": {
      "type": "proxy",
      "url": "https://news.ycombinator.com",
      "skip_tls_verify_host": true
    },
    "transforms": [
      {
        "type": "optimized_html",
        "content_types": [
          "text/html"
        ],
        "optimized_format_options": {
          "strip_comments": true,
          "remove_trailing_slashes": true,
          "optimize_attributes": true
        },
        "add_to_tags": [
          {
            "tag": "head",
            "add_before_end_tag": false,
            "content": "<script>console.log('Proxy injected script');</script>"
          }
        ]
      }
    ],
    "workspace_id": "test-tenant",
    "version": "1.0-test"
  }
}
