{
  "cache-max-age.test": {
    "id": "cache-max-age",
    "hostname": "cache-max-age.test",
    "cache_settings": {
      "disabled": false,
      "level": "l2",
      "ttl": "5m",
      "cache_control": {
        "respect_cache_control": true,
        "respect_max_age": true
      }
    },
    "action": {
      "type": "proxy",
      "url": "http://e2e-test-server:8090/cache-test/max-age?max_age=5"
    }
  }
}