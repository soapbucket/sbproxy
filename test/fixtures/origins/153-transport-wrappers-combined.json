{
  "transport-wrappers-combined.test": {
    "id": "transport-wrappers-combined",
    "hostname": "transport-wrappers-combined.test",
    "action": {
      "type": "proxy",
      "url": "http://e2e-test-server:8090",
      "transport_wrappers": {
        "health_check": {
          "enabled": true,
          "type": "http",
          "endpoint": "/health",
          "interval": "5s",
          "timeout": "2s",
          "healthy_threshold": 1,
          "unhealthy_threshold": 1,
          "expected_status": 200
        },
        "hedging": {
          "enabled": true,
          "delay": "50ms",
          "max_hedges": 1,
          "max_cost_ratio": 0.3
        },
        "retry": {
          "enabled": true,
          "max_retries": 3,
          "initial_delay": "100ms",
          "max_delay": "5s",
          "multiplier": 2.0,
          "jitter": 0.1,
          "retryable_status": [502, 503, 504, 429]
        }
      }
    }
  },
  "transport-wrappers-combined-full.test": {
    "id": "transport-wrappers-combined-full",
    "hostname": "transport-wrappers-combined-full.test",
    "action": {
      "type": "proxy",
      "url": "http://e2e-test-server:8090",
      "transport_wrappers": {
        "health_check": {
          "enabled": true,
          "type": "http",
          "endpoint": "/health",
          "interval": "10s",
          "timeout": "3s",
          "healthy_threshold": 2,
          "unhealthy_threshold": 2,
          "expected_status": 200
        },
        "hedging": {
          "enabled": true,
          "delay": "100ms",
          "max_hedges": 2,
          "methods": ["GET"],
          "max_cost_ratio": 0.2
        },
        "retry": {
          "enabled": true,
          "max_retries": 5,
          "initial_delay": "200ms",
          "max_delay": "10s",
          "multiplier": 2.0,
          "jitter": 0.2,
          "retryable_status": [502, 503, 504, 429, 500]
        }
      }
    }
  }
}

