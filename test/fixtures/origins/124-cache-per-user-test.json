{
  "cache-per-user.test": {
    "id": "cache-per-user",
    "hostname": "cache-per-user.test",
    "authentication": {
      "type": "api_key",
      "disabled": false,
      "header_name": "X-API-Key",
      "api_keys": [
        "user1-cache-key",
        "user2-cache-key"
      ]
    },
    "cache_settings": {
      "disabled": false,
      "level": "l2",
      "ttl": "1m",
      "cache_key_pattern": "{{hostname}}:{{path}}:{{auth_key}}",
      "private_cache": true
    },
    "action": {
      "type": "proxy",
      "url": "http://e2e-test-server:8090/cache/user-data"
    }
  }
}