{
  "annotations": {
    "list": []
  },
  "id": null,
  "title": "SBproxy Traces Overview",
  "description": "OTel trace ingestion and span pillar breakdown per adr-observability.md (A1.4). Span names follow sbproxy.<pillar>.<verb>; exemplars on histograms link straight into Tempo.",
  "tags": [
    "sbproxy",
    "wave1",
    "traces"
  ],
  "style": "dark",
  "timezone": "browser",
  "editable": false,
  "graphTooltip": 1,
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "refresh": "30s",
  "schemaVersion": 39,
  "version": 1,
  "templating": {
    "list": [
      {
        "name": "prometheus_datasource",
        "label": "Prometheus",
        "type": "datasource",
        "query": "prometheus",
        "current": {
          "selected": false,
          "text": "Prometheus",
          "value": "Prometheus"
        },
        "hide": 0,
        "refresh": 1,
        "regex": "",
        "skipUrlSync": false,
        "options": []
      },
      {
        "name": "tempo_datasource",
        "label": "Tempo",
        "type": "datasource",
        "query": "tempo",
        "current": {
          "selected": false,
          "text": "Tempo",
          "value": "Tempo"
        },
        "hide": 0,
        "refresh": 1,
        "regex": "",
        "skipUrlSync": false,
        "options": []
      },
      {
        "name": "tenant_id",
        "label": "Tenant",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${prometheus_datasource}"
        },
        "query": "label_values(sbproxy_spans_emitted_total, tenant_id)",
        "includeAll": true,
        "multi": true,
        "refresh": 2,
        "current": {
          "selected": false,
          "text": "All",
          "value": "$__all"
        },
        "options": []
      },
      {
        "name": "pillar",
        "label": "Pillar",
        "type": "custom",
        "query": "intake,policy,action,transform,ledger,rail,audit,notify",
        "current": {
          "selected": false,
          "text": "All",
          "value": "$__all"
        },
        "includeAll": true,
        "multi": true,
        "options": [
          {
            "selected": true,
            "text": "All",
            "value": "$__all"
          },
          {
            "selected": false,
            "text": "intake",
            "value": "intake"
          },
          {
            "selected": false,
            "text": "policy",
            "value": "policy"
          },
          {
            "selected": false,
            "text": "action",
            "value": "action"
          },
          {
            "selected": false,
            "text": "transform",
            "value": "transform"
          },
          {
            "selected": false,
            "text": "ledger",
            "value": "ledger"
          },
          {
            "selected": false,
            "text": "rail",
            "value": "rail"
          },
          {
            "selected": false,
            "text": "audit",
            "value": "audit"
          },
          {
            "selected": false,
            "text": "notify",
            "value": "notify"
          }
        ]
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Trace ingestion rate",
      "description": "Spans-per-second and traces-per-second emitted by the proxy. A drop to zero under traffic indicates the OTLP exporter is failing.",
      "type": "stat",
      "gridPos": {
        "h": 5,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${prometheus_datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "graphMode": "area",
        "textMode": "value_and_name",
        "colorMode": "value",
        "orientation": "horizontal",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(sbproxy_spans_emitted_total{tenant_id=~\"$tenant_id\"}[$__rate_interval]))",
          "legendFormat": "spans/s",
          "datasource": {
            "type": "prometheus",
            "uid": "${prometheus_datasource}"
          }
        },
        {
          "refId": "B",
          "expr": "sum(rate(sbproxy_traces_started_total{tenant_id=~\"$tenant_id\"}[$__rate_interval]))",
          "legendFormat": "traces/s",
          "datasource": {
            "type": "prometheus",
            "uid": "${prometheus_datasource}"
          }
        }
      ]
    },
    {
      "id": 2,
      "title": "Spans by pillar",
      "description": "Span emission rate broken down by ADR pillar (intake, policy, action, transform, ledger, rail, audit, notify). Honors the span-naming convention sbproxy.<pillar>.<verb>.",
      "type": "timeseries",
      "gridPos": {
        "h": 9,
        "w": 24,
        "x": 0,
        "y": 5
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${prometheus_datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "drawStyle": "line",
            "stacking": {
              "mode": "normal",
              "group": "A"
            }
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": [
            "mean",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (pillar) (rate(sbproxy_spans_emitted_total{tenant_id=~\"$tenant_id\",pillar=~\"$pillar\"}[$__rate_interval]))",
          "legendFormat": "{{pillar}}",
          "datasource": {
            "type": "prometheus",
            "uid": "${prometheus_datasource}"
          }
        }
      ]
    },
    {
      "id": 3,
      "title": "Error spans by pillar (with exemplars)",
      "description": "Error spans correlate to status_code=ERROR per OTel semconv. Click an exemplar dot to open the trace in Tempo.",
      "type": "timeseries",
      "gridPos": {
        "h": 9,
        "w": 24,
        "x": 0,
        "y": 14
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${prometheus_datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "drawStyle": "line"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byRegexp",
              "options": ".*"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "red",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": [
            "mean",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (pillar) (rate(sbproxy_spans_emitted_total{status_code=\"ERROR\",tenant_id=~\"$tenant_id\",pillar=~\"$pillar\"}[$__rate_interval]))",
          "legendFormat": "{{pillar}}",
          "exemplar": true,
          "datasource": {
            "type": "prometheus",
            "uid": "${prometheus_datasource}"
          }
        }
      ]
    },
    {
      "id": 4,
      "title": "Recent error traces (Tempo)",
      "description": "Tempo TraceQL query for spans with status=error in the selected time range. Click a row to open the trace.",
      "type": "table",
      "gridPos": {
        "h": 9,
        "w": 24,
        "x": 0,
        "y": 23
      },
      "datasource": {
        "type": "tempo",
        "uid": "${tempo_datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "align": "auto",
            "displayMode": "auto"
          }
        },
        "overrides": []
      },
      "options": {
        "showHeader": true,
        "footer": {
          "enablePagination": true,
          "show": false
        }
      },
      "targets": [
        {
          "refId": "A",
          "queryType": "traceqlSearch",
          "filters": [
            {
              "id": "service-name",
              "tag": "service.name",
              "operator": "=",
              "scope": "resource",
              "value": [
                "sbproxy"
              ]
            },
            {
              "id": "status",
              "tag": "status",
              "operator": "=",
              "scope": "intrinsic",
              "value": [
                "error"
              ]
            }
          ],
          "limit": 20,
          "tableType": "traces",
          "datasource": {
            "type": "tempo",
            "uid": "${tempo_datasource}"
          }
        }
      ]
    }
  ]
}
