{
  "annotations": {
    "list": []
  },
  "id": null,
  "title": "SBproxy Policy Triggers",
  "description": "Policy enforcement signals: rate-limit, IP filter, WAF, content-negotiate, AI crawl. Backed by sbproxy_policy_triggers_total per adr-metric-cardinality.md.",
  "tags": [
    "sbproxy",
    "wave1",
    "policy"
  ],
  "style": "dark",
  "timezone": "browser",
  "editable": false,
  "graphTooltip": 1,
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "refresh": "1m",
  "schemaVersion": 39,
  "version": 1,
  "templating": {
    "list": [
      {
        "name": "prometheus_datasource",
        "label": "Prometheus",
        "type": "datasource",
        "query": "prometheus",
        "current": {
          "selected": false,
          "text": "Prometheus",
          "value": "Prometheus"
        },
        "hide": 0,
        "refresh": 1,
        "regex": "",
        "skipUrlSync": false,
        "options": []
      },
      {
        "name": "tenant_id",
        "label": "Tenant",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${prometheus_datasource}"
        },
        "query": "label_values(sbproxy_policy_triggers_total, tenant_id)",
        "includeAll": true,
        "multi": true,
        "refresh": 2,
        "current": {
          "selected": false,
          "text": "All",
          "value": "$__all"
        },
        "options": []
      },
      {
        "name": "decision",
        "label": "Decision",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${prometheus_datasource}"
        },
        "query": "label_values(sbproxy_policy_triggers_total{tenant_id=~\"$tenant_id\"}, decision)",
        "includeAll": true,
        "multi": true,
        "refresh": 2,
        "current": {
          "selected": false,
          "text": "All",
          "value": "$__all"
        },
        "options": []
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Total policy triggers per hour",
      "description": "Sum of policy triggers in the last 1h, filtered by tenant and decision. Spike indicates traffic shift or attack.",
      "type": "stat",
      "gridPos": {
        "h": 5,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${prometheus_datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 100
              },
              {
                "color": "red",
                "value": 1000
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "graphMode": "area",
        "textMode": "value_and_name",
        "colorMode": "value",
        "orientation": "horizontal",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(sbproxy_policy_triggers_total{tenant_id=~\"$tenant_id\",decision=~\"$decision\"}[1h]))",
          "legendFormat": "triggers / hr",
          "datasource": {
            "type": "prometheus",
            "uid": "${prometheus_datasource}"
          }
        }
      ]
    },
    {
      "id": 2,
      "title": "Triggers by policy type",
      "description": "Stacked rate per policy module (rate-limit, ip-filter, waf, content-negotiate, ai-crawl, ...). Distribution should match the active sb.yml.",
      "type": "barchart",
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 5
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${prometheus_datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 80,
            "stacking": {
              "mode": "normal",
              "group": "A"
            },
            "lineWidth": 1
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": [
            "sum"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "orientation": "auto",
        "stacking": "normal",
        "xTickLabelRotation": 0,
        "xTickLabelSpacing": 0
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (policy) (rate(sbproxy_policy_triggers_total{tenant_id=~\"$tenant_id\",decision=~\"$decision\"}[$__rate_interval]))",
          "legendFormat": "{{policy}}",
          "datasource": {
            "type": "prometheus",
            "uid": "${prometheus_datasource}"
          }
        }
      ]
    },
    {
      "id": 3,
      "title": "Triggers by route x policy",
      "description": "Heatmap of route x policy intersections. Hot cells flag a route that is repeatedly tripping a single policy.",
      "type": "heatmap",
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 15
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${prometheus_datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "scaleDistribution": {
              "type": "linear"
            },
            "hideFrom": {
              "tooltip": false,
              "viz": false,
              "legend": false
            }
          }
        },
        "overrides": []
      },
      "options": {
        "calculate": false,
        "yAxis": {
          "axisPlacement": "left",
          "reverse": false,
          "unit": "short"
        },
        "rowsFrame": {
          "layout": "auto"
        },
        "color": {
          "mode": "scheme",
          "scheme": "Oranges",
          "fill": "dark-orange",
          "scale": "exponential",
          "exponent": 0.5,
          "steps": 64,
          "reverse": false
        },
        "cellGap": 1,
        "filterValues": {
          "le": 1E-9
        },
        "tooltip": {
          "show": true,
          "yHistogram": false
        },
        "legend": {
          "show": true
        },
        "exemplars": {
          "color": "rgba(255,0,255,0.7)"
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (route, policy) (rate(sbproxy_policy_triggers_total{tenant_id=~\"$tenant_id\",decision=~\"$decision\"}[$__rate_interval]))",
          "legendFormat": "{{route}} | {{policy}}",
          "datasource": {
            "type": "prometheus",
            "uid": "${prometheus_datasource}"
          }
        }
      ]
    }
  ]
}
