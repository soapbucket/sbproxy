{
  "annotations": {
    "list": []
  },
  "id": null,
  "title": "SBproxy Overview",
  "description": "Wave 1 substrate overview. Top-line RPS, error rate, latency, and ledger health. Drives the first triage panel an operator opens.",
  "tags": [
    "sbproxy",
    "wave1",
    "overview"
  ],
  "style": "dark",
  "timezone": "browser",
  "editable": false,
  "graphTooltip": 1,
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "refresh": "30s",
  "schemaVersion": 39,
  "version": 1,
  "templating": {
    "list": [
      {
        "name": "prometheus_datasource",
        "label": "Prometheus",
        "type": "datasource",
        "query": "prometheus",
        "current": {
          "selected": false,
          "text": "Prometheus",
          "value": "Prometheus"
        },
        "hide": 0,
        "refresh": 1,
        "regex": "",
        "skipUrlSync": false,
        "options": []
      },
      {
        "name": "tempo_datasource",
        "label": "Tempo",
        "type": "datasource",
        "query": "tempo",
        "current": {
          "selected": false,
          "text": "Tempo",
          "value": "Tempo"
        },
        "hide": 0,
        "refresh": 1,
        "regex": "",
        "skipUrlSync": false,
        "options": []
      },
      {
        "name": "tenant_id",
        "label": "Tenant",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${prometheus_datasource}"
        },
        "query": "label_values(sbproxy_requests_total, tenant_id)",
        "includeAll": true,
        "multi": true,
        "refresh": 2,
        "current": {
          "selected": false,
          "text": "All",
          "value": "$__all"
        },
        "options": []
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Requests per second",
      "description": "Total rate(sbproxy_requests_total) across the selected tenants. Headline traffic indicator.",
      "type": "stat",
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${prometheus_datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "graphMode": "area",
        "textMode": "auto",
        "colorMode": "value",
        "orientation": "auto",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(sbproxy_requests_total{tenant_id=~\"$tenant_id\"}[$__rate_interval]))",
          "datasource": {
            "type": "prometheus",
            "uid": "${prometheus_datasource}"
          }
        }
      ]
    },
    {
      "id": 2,
      "title": "Error rate (5xx)",
      "description": "5xx ratio of total requests over the rate-interval. Tracks SLO-AVAIL-INBOUND.",
      "type": "stat",
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${prometheus_datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.001
              },
              {
                "color": "red",
                "value": 0.01
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "graphMode": "area",
        "textMode": "auto",
        "colorMode": "value",
        "orientation": "auto",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(sbproxy_requests_total{status_class=\"5xx\",tenant_id=~\"$tenant_id\"}[$__rate_interval])) / sum(rate(sbproxy_requests_total{tenant_id=~\"$tenant_id\"}[$__rate_interval]))",
          "datasource": {
            "type": "prometheus",
            "uid": "${prometheus_datasource}"
          }
        }
      ]
    },
    {
      "id": 3,
      "title": "Latency p95",
      "description": "Inbound request p95 (rail wait excluded). Tracks SLO-LATENCY-P95 (< 30 ms target).",
      "type": "stat",
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${prometheus_datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.03
              },
              {
                "color": "red",
                "value": 0.05
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "graphMode": "area",
        "textMode": "auto",
        "colorMode": "value",
        "orientation": "auto",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(sbproxy_request_duration_seconds_bucket{tenant_id=~\"$tenant_id\"}[$__rate_interval])))",
          "datasource": {
            "type": "prometheus",
            "uid": "${prometheus_datasource}"
          }
        }
      ]
    },
    {
      "id": 4,
      "title": "Latency p99",
      "description": "Inbound request p99 (rail wait excluded). Tracks SLO-LATENCY-P99 (< 50 ms target, paging tier).",
      "type": "stat",
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${prometheus_datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.05
              },
              {
                "color": "red",
                "value": 0.1
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "graphMode": "area",
        "textMode": "auto",
        "colorMode": "value",
        "orientation": "auto",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.99, sum by (le) (rate(sbproxy_request_duration_seconds_bucket{tenant_id=~\"$tenant_id\"}[$__rate_interval])))",
          "datasource": {
            "type": "prometheus",
            "uid": "${prometheus_datasource}"
          }
        }
      ]
    },
    {
      "id": 5,
      "title": "Requests by status class",
      "description": "Stacked rate per status_class (2xx/3xx/4xx/5xx). Quickest read on traffic shape changes.",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 5
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${prometheus_datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "drawStyle": "line",
            "stacking": {
              "mode": "normal",
              "group": "A"
            }
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "5xx"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "red",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "4xx"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "orange",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "3xx"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "blue",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "2xx"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "green",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (status_class) (rate(sbproxy_requests_total{tenant_id=~\"$tenant_id\"}[$__rate_interval]))",
          "legendFormat": "{{status_class}}",
          "datasource": {
            "type": "prometheus",
            "uid": "${prometheus_datasource}"
          }
        }
      ]
    },
    {
      "id": 6,
      "title": "Top routes",
      "description": "Top 10 routes by request rate. Honors the route label cardinality budget in adr-metric-cardinality.md.",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 5
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${prometheus_datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "drawStyle": "line"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "mean",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "topk(10, sum by (route) (rate(sbproxy_requests_total{tenant_id=~\"$tenant_id\"}[$__rate_interval])))",
          "legendFormat": "{{route}}",
          "datasource": {
            "type": "prometheus",
            "uid": "${prometheus_datasource}"
          }
        }
      ]
    },
    {
      "id": 7,
      "title": "Ledger redeem success rate",
      "description": "Success ratio of sbproxy_ledger_redeem_total. Tracks SLO-LEDGER-REDEEM (99.95%, paging tier).",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 13
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${prometheus_datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.99
              },
              {
                "color": "green",
                "value": 0.9995
              }
            ]
          },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "drawStyle": "line"
          },
          "min": 0.95,
          "max": 1
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "single",
          "sort": "none"
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(sbproxy_ledger_redeem_total{result=\"success\",tenant_id=~\"$tenant_id\"}[$__rate_interval])) / sum(rate(sbproxy_ledger_redeem_total{tenant_id=~\"$tenant_id\"}[$__rate_interval]))",
          "legendFormat": "success",
          "datasource": {
            "type": "prometheus",
            "uid": "${prometheus_datasource}"
          }
        }
      ]
    },
    {
      "id": 8,
      "title": "Ledger redeem latency p95 / p99",
      "description": "Outbound redeem call latency histogram, with exemplars linking each spike to a Tempo trace per adr-observability.md.",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 13
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${prometheus_datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "drawStyle": "line"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(sbproxy_ledger_redeem_duration_seconds_bucket{tenant_id=~\"$tenant_id\"}[$__rate_interval])))",
          "legendFormat": "p95",
          "datasource": {
            "type": "prometheus",
            "uid": "${prometheus_datasource}"
          },
          "exemplar": true
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.99, sum by (le) (rate(sbproxy_ledger_redeem_duration_seconds_bucket{tenant_id=~\"$tenant_id\"}[$__rate_interval])))",
          "legendFormat": "p99",
          "datasource": {
            "type": "prometheus",
            "uid": "${prometheus_datasource}"
          },
          "exemplar": true
        }
      ]
    }
  ]
}
