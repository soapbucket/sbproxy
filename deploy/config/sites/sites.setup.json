  "api-v2.localhost": {
    "id": "api-v2-migration",
    "hostname": "api-v2.localhost",
    "workspace_id": "default",
    "version": "1.0",
    "forward_rules": [
      {
        "hostname": "api-v1.localhost",
        "rules": [{ "path": { "prefix": "/" } }]
      }
    ],
    "action": {
      "type": "static",
      "status_code": 404,
      "body": "Not Found"
    },
    "transforms": [
      {
        "type": "lua_json",
        "content_types": ["application/json"],
        "lua_script": "function modify_json(data, ctx)\n  -- Convert snake_case to camelCase\n  local function to_camel_case(str)\n    return str:gsub('_(%l)', function(c) return c:upper() end)\n  end\n  \n  -- Map country codes\n  local country_map = {\n    UNITED_STATES = 'US',\n    UNITED_KINGDOM = 'GB',\n    GERMANY = 'DE',\n    FRANCE = 'FR'\n  }\n  \n  local function transform_keys(obj)\n    if type(obj) ~= 'table' then return obj end\n    local result = {}\n    for k, v in pairs(obj) do\n      local new_key = to_camel_case(k)\n      local new_val = transform_keys(v)\n      -- Apply country code mapping\n      if new_key == 'countryCode' and country_map[new_val] then\n        new_val = country_map[new_val]\n      end\n      result[new_key] = new_val\n    end\n    return result\n  end\n  \n  return transform_keys(data)\nend",
        "timeout": "100ms"
      }
    ]
  },
  "weather-mcp.localhost": {
    "id": "weather-mcp-server",
    "hostname": "weather-mcp.localhost",
    "workspace_id": "default",
    "version": "1.0",
    "action": {
      "type": "mcp",
      "server_info": {
        "name": "weather-mcp-server",
        "version": "1.0.0"
      },
      "capabilities": {
        "tools": { "listChanged": false },
        "resources": { "subscribe": false, "listChanged": false }
      },
      "tools": [
        {
          "name": "get_alerts",
          "description": "Get weather alerts for a US state. Returns current weather alerts and warnings.",
          "input_schema": {
            "type": "object",
            "properties": {
              "state": {
                "type": "string",
                "description": "Two-letter US state code (e.g., CA, NY, TX)"
              }
            },
            "required": ["state"]
          },
          "handler": {
            "type": "proxy",
            "proxy": {
              "url": "https://api.weather.gov/alerts/active?area={{ tool.arguments.state }}",
              "method": "GET",
              "headers": {
                "User-Agent": "SoapBucket-MCP-Weather/1.0",
                "Accept": "application/geo+json"
              }
            },
            "lua_script": "function modify_json(data, ctx)\n  data.alert_count = data.features and #data.features or 0\n  data.has_alerts = data.alert_count > 0\n  return data\nend",
            "response_template": "{{#has_alerts}}Found {{alert_count}} active alert(s) for {{tool.arguments.state}}:\n\n{{#features}}## {{properties.event}}\n**Severity:** {{properties.severity}}\n**Areas:** {{properties.areaDesc}}\n**Expires:** {{properties.expires}}\n\n{{properties.description}}\n\n---\n{{/features}}{{/has_alerts}}{{^has_alerts}}No active weather alerts for {{tool.arguments.state}}.{{/has_alerts}}"
          },
          "timeout": "10s"
        },
        {
          "name": "get_forecast",
          "description": "Get weather forecast for a specific location using latitude and longitude coordinates.",
          "input_schema": {
            "type": "object",
            "properties": {
              "latitude": {
                "type": "number",
                "description": "Latitude of the location (e.g., 37.7749 for San Francisco)"
              },
              "longitude": {
                "type": "number",
                "description": "Longitude of the location (e.g., -122.4194 for San Francisco)"
              }
            },
            "required": ["latitude", "longitude"]
          },
          "handler": {
            "type": "orchestration",
            "orchestration": {
              "steps": [
                {
                  "name": "get_grid",
                  "callback": {
                    "url": "https://api.weather.gov/points/{{ tool.arguments.latitude }},{{ tool.arguments.longitude }}",
                    "method": "GET",
                    "headers": {
                      "User-Agent": "SoapBucket-MCP-Weather/1.0",
                      "Accept": "application/geo+json"
                    }
                  }
                },
                {
                  "name": "get_forecast",
                  "depends_on": ["get_grid"],
                  "callback": {
                    "url": "{{ steps.get_grid.response.properties.forecast }}",
                    "method": "GET",
                    "headers": {
                      "User-Agent": "SoapBucket-MCP-Weather/1.0",
                      "Accept": "application/geo+json"
                    }
                  }
                }
              ]
            },
            "lua_script": "function modify_json(data, ctx)\n  local periods = data.steps and data.steps.get_forecast and data.steps.get_forecast.response and data.steps.get_forecast.response.properties and data.steps.get_forecast.response.properties.periods\n  local sliced = {}\n  if periods then\n    for i = 1, math.min(7, #periods) do sliced[i] = periods[i] end\n  end\n  data.forecast_periods = sliced\n  return data\nend",
            "response_template": "# Weather Forecast\n**Location:** {{tool.arguments.latitude}}, {{tool.arguments.longitude}}\n\n{{#forecast_periods}}## {{name}}\n**Temperature:** {{temperature}} {{temperatureUnit}}\n**Wind:** {{windSpeed}} {{windDirection}}\n\n{{detailedForecast}}\n\n{{/forecast_periods}}"
          },
          "timeout": "30s"
        }
      ],
      "resources": [
        {
          "uri": "weather://alerts/active",
          "name": "Active Weather Alerts",
          "description": "All currently active weather alerts across the United States",
          "mime_type": "application/json",
          "handler": {
            "type": "proxy",
            "proxy": {
              "url": "https://api.weather.gov/alerts/active",
              "headers": {
                "User-Agent": "SoapBucket-MCP-Weather/1.0"
              }
            }
          }
        }
      ],
      "default_timeout": "30s",
      "error_handling": {
        "retry_upstream_errors": true,
        "circuit_breaker": {
          "enabled": true,
          "failure_threshold": 5,
          "reset_timeout": "30s"
        }
      }
    }
  }
}
