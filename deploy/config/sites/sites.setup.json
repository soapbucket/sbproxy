  "transform.localhost": {
    "id": "hn-transform",
    "hostname": "transform.localhost",
    "workspace_id": "default",
    "version": "1.0",
    "action": {
      "type": "proxy",
      "url": "https://news.ycombinator.com",
      "skip_tls_verify_host": true,
      "enable_http3": true
    },
    "transforms": [
      {
        "type": "optimized_html",
        "content_types": ["text/html"],
        "add_to_tags": [
          {
            "tag": "body",
            "add_before_end_tag": false,
            "content": "<div style='position:fixed;top:0;left:0;width:100%;background:red;color:white;text-align:center;z-index:9999;'>Proxied by SoapBucket</div>"
          },
          {
            "tag": "head",
            "content": "<script>console.log('Injected Script')</script>"
          }
        ]
      },
      {
        "type": "replace_strings",
        "replacements": [
          {
            "find": "Hacker News",
            "replace": "SoapBucket News"
          }
        ]
      }
    ]
  },
  "api.localhost": {
    "id": "api-demo",
    "hostname": "api.localhost",
    "workspace_id": "default",
    "version": "1.0",
    "action": {
      "type": "proxy",
      "url": "https://postman-echo.com",
