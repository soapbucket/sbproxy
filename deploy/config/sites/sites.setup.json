  "secure.localhost": {
    "id": "secure-demo",
    "hostname": "secure.localhost",
    "workspace_id": "default",
    "version": "1.0",
    "action": {
      "type": "proxy",
      "url": "https://postman-echo.com/get",
      "skip_tls_verify_host": true,
      "enable_http3": true
    },
    "policies": [
      {
        "type": "rate_limiting",
        "algorithm": "sliding_window",
        "requests_per_minute": 5,
        "burst_size": 2,
        "headers": {
          "enabled": true,
          "include_retry_after": true,
          "include_remaining": true
        }
      },
      {
        "type": "waf",
        "action_on_match": "block",
        "owasp_crs": {
          "enabled": true,
          "paranoia_level": 1
        },
        "custom_rules": [
          {
            "id": "block-sql",
            "action": "block",
            "operator": "rx",
            "pattern": "(?i)(union\\s+select|drop\\s+table)",
            "variables": [{ "name": "ARGS" }]
          }
        ]
      }
    ]
  },
