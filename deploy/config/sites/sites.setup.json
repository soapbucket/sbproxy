      "enable_http3": true
    },
    "request_modifiers": [
      {
        "headers": {
          "set": {
            "X-Proxy-Auth": "demo-token"
          }
        }
      }
    ],
    "transforms": [
      {
        "type": "json",
        "content_types": ["application/json"],
        "pretty_print": true,
        "rules": [
          {
            "path": "$.headers.x-forwarded-proto",
            "value": "REDACTED"
          }
        ]
      }
    ]
  },
