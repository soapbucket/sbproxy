      "parallel": true,
      "timeout": "10s",
      "steps": [
        {
          "name": "get_user",
          "callback": {
            "url": "https://jsonplaceholder.typicode.com/users/1",
            "method": "GET"
          }
        },
        {
          "name": "get_posts",
          "callback": {
            "url": "https://jsonplaceholder.typicode.com/posts?userId=1&_limit=3",
            "method": "GET"
          }
        }
      ],
      "response_builder": {
        "template": "{\n  \"user\": {{{steps.get_user.response_json}}},\n  \"posts\": {{{steps.get_posts.response_json}}},\n  \"meta\": {\n    \"user_ms\": {{steps.get_user.duration}},\n    \"posts_ms\": {{steps.get_posts.duration}},\n    \"total_ms\": {{total_duration}}\n  }\n}",
        "content_type": "application/json",
        "status_code": 200,
        "headers": {
          "X-Composed-By": "SoapBucket Orchestration"
        }
      }
