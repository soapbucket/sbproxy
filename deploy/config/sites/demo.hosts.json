  "api-bridge.demo.soapbucket.com": {
    "id": "api-bridge-demo",
    "hostname": "api-bridge.demo.soapbucket.com",
    "workspace_id": "demo",
    "version": "1.0.0",
    "action": {
      "type": "mcp",
      "server_info": {
        "name": "api-bridge-server",
        "version": "1.0.0"
      },
      "capabilities": {
        "tools": { "listChanged": false },
        "resources": { "subscribe": false, "listChanged": false }
      },
      "tools": [
        {
          "name": "list_posts",
          "description": "List recent blog posts. Returns title, body, and author ID for each post.",
          "input_schema": {
            "type": "object",
            "properties": {
              "limit": { "type": "integer", "description": "Maximum number of posts to return (1-100)", "default": 10 }
            }
          },
          "handler": {
            "type": "proxy",
            "proxy": {
              "url": "https://jsonplaceholder.typicode.com/posts",
              "method": "GET",
              "headers": { "Accept": "application/json" }
            },
            "lua_script": "function modify_json(data, ctx)\n  local limit = tonumber(data.tool and data.tool.arguments and data.tool.arguments.limit) or 10\n  local posts = {}\n  if data.result and type(data.result) == 'table' then\n    for i = 1, math.min(limit, #data.result) do\n      local post = data.result[i]\n      local body = post.body or ''\n      if #body > 120 then body = string.sub(body, 1, 120) .. '...' end\n      post.body_short = body\n      posts[i] = post\n    end\n    data.total_count = #data.result\n  else\n    data.total_count = 0\n  end\n  data.posts = posts\n  return data\nend",
            "response_template": "{{#posts}}**{{title}}** (Post #{{id}})\nAuthor ID: {{userId}}\n{{body_short}}\n\n{{/posts}}Found {{total_count}} total posts."
          },
          "timeout": "10s"
        },
        {
          "name": "get_post",
          "description": "Get a specific blog post by ID, including its comments.",
          "input_schema": {
            "type": "object",
            "properties": {
              "post_id": { "type": "integer", "description": "The post ID to retrieve" }
            },
            "required": ["post_id"]
          },
          "handler": {
            "type": "orchestration",
            "orchestration": {
              "steps": [
                {
                  "name": "fetch_post",
                  "callback": {
                    "url": "https://jsonplaceholder.typicode.com/posts/{{ tool.arguments.post_id }}",
                    "method": "GET",
                    "headers": { "Accept": "application/json" }
                  }
                },
                {
                  "name": "fetch_comments",
                  "callback": {
                    "url": "https://jsonplaceholder.typicode.com/posts/{{ tool.arguments.post_id }}/comments",
                    "method": "GET",
                    "headers": { "Accept": "application/json" }
                  }
                }
              ],
              "parallel": true,
              "timeout": "10s"
            },
            "lua_script": "function modify_json(data, ctx)\n  local comments = data.steps and data.steps.fetch_comments and data.steps.fetch_comments.response\n  local trimmed = {}\n  if comments and type(comments) == 'table' then\n    for i, c in ipairs(comments) do\n      local body = c.body or ''\n      if #body > 100 then body = string.sub(body, 1, 100) .. '...' end\n      c.body_short = body\n      trimmed[i] = c\n    end\n    data.comment_count = #comments\n  else\n    data.comment_count = 0\n  end\n  data.comments = trimmed\n  return data\nend",
            "response_template": "## {{steps.fetch_post.response.title}}\n\nAuthor ID: {{steps.fetch_post.response.userId}}\n\n{{steps.fetch_post.response.body}}\n\n---\nComments ({{comment_count}}):\n{{#comments}}{{name}} ({{email}}): {{body_short}}\n{{/comments}}"
          },
          "timeout": "15s"
        },
        {
          "name": "create_post",
          "description": "Create a new blog post with a title and body.",
          "input_schema": {
            "type": "object",
            "properties": {
              "title": { "type": "string", "description": "Post title" },
              "content": { "type": "string", "description": "Post body content" },
              "user_id": { "type": "integer", "description": "Author user ID", "default": 1 }
            },
            "required": ["title", "content"]
          },
          "handler": {
            "type": "proxy",
            "proxy": {
              "url": "https://jsonplaceholder.typicode.com/posts",
              "method": "POST",
              "headers": { "Content-Type": "application/json", "Accept": "application/json" },
              "body": "{\"title\": \"{{tool.arguments.title}}\", \"body\": \"{{tool.arguments.content}}\", \"userId\": {{#tool.arguments.user_id}}{{tool.arguments.user_id}}{{/tool.arguments.user_id}}{{^tool.arguments.user_id}}1{{/tool.arguments.user_id}}}"
            },
            "response_template": "Post created successfully!\n\n- ID: {{ result.id }}\n- Title: {{ result.title }}\n- Author: User {{ result.userId }}"
          },
          "timeout": "10s"
        },
        {
          "name": "get_user",
          "description": "Get user profile information.",
          "input_schema": {
            "type": "object",
            "properties": {
              "user_id": { "type": "integer", "description": "User ID to look up (1-10)" }
            },
            "required": ["user_id"]
          },
          "handler": {
            "type": "proxy",
            "proxy": {
              "url": "https://jsonplaceholder.typicode.com/users/{{ tool.arguments.user_id }}",
              "method": "GET",
              "headers": { "Accept": "application/json" }
            },
            "response_template": "{{ result.name }} (@{{ result.username }})\n- Email: {{ result.email }}\n- Phone: {{ result.phone }}\n- Company: {{ result.company.name }}"
          },
          "timeout": "10s"
        },
        {
          "name": "create_and_verify_post",
          "description": "Create a blog post and immediately verify it was created. Macro Tool pattern.",
          "input_schema": {
            "type": "object",
            "properties": {
              "title": { "type": "string", "description": "Post title" },
              "content": { "type": "string", "description": "Post body content" }
            },
            "required": ["title", "content"]
          },
          "handler": {
            "type": "orchestration",
            "orchestration": {
              "steps": [
                {
                  "name": "create",
                  "callback": {
                    "url": "https://jsonplaceholder.typicode.com/posts",
                    "method": "POST",
                    "headers": { "Content-Type": "application/json", "Accept": "application/json" },
                    "body": "{\"title\": \"{{ tool.arguments.title }}\", \"body\": \"{{ tool.arguments.content }}\", \"userId\": 1}"
                  }
                },
                {
                  "name": "verify",
                  "depends_on": ["create"],
                  "callback": {
                    "url": "https://jsonplaceholder.typicode.com/posts/{{ steps.create.response.id }}",
                    "method": "GET",
                    "headers": { "Accept": "application/json" }
                  }
                }
              ],
              "parallel": false,
              "timeout": "15s"
            },
            "response_template": "Post created and verified!\n\nCreated: ID {{ steps.create.response.id }}, Title: {{ steps.create.response.title }}\nVerified: Post {{ steps.verify.response.id }} exists."
          },
          "timeout": "20s"
        },
        {
          "name": "simulate_delete_post",
          "description": "Simulate deleting a post (dry-run, Shadow Mode pattern).",
          "input_schema": {
            "type": "object",
            "properties": {
              "post_id": { "type": "integer", "description": "Post ID to simulate deleting" }
            },
            "required": ["post_id"]
          },
          "handler": {
            "type": "static",
            "static": { "content": "" },
            "response_template": "DRY RUN: Simulated deletion of Post #{{ tool.arguments.post_id }}\nStatus: simulated_success\nAction: DELETE /posts/{{ tool.arguments.post_id }}\nResult: Post would have been deleted."
          },
          "timeout": "5s"
        }
      ],
      "resources": [
        {
          "uri": "posts://recent",
          "name": "Recent Posts",
          "description": "The 10 most recent blog posts",
          "mime_type": "application/json",
          "handler": {
            "type": "proxy",
            "proxy": {
              "url": "https://jsonplaceholder.typicode.com/posts?_limit=10",
              "method": "GET",
              "headers": { "Accept": "application/json" }
            }
          }
        },
        {
          "uri": "users://directory",
