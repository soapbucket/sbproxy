  "chain.localhost": {
    "id": "orchestration-chain",
    "hostname": "chain.localhost",
    "workspace_id": "demo",
    "version": "1.0.0",
    "action": {
      "type": "orchestration",
      "timeout": "15s",
      "steps": [
        {
