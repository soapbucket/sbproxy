      ],
      "response_builder": {
        "template": "{\n  \"user\": {\n    \"id\": {{steps.get_user.response.id}},\n    \"name\": \"{{steps.get_user.response.name}}\",\n    \"email\": \"{{steps.get_user.response.email}}\"\n  },\n  \"posts\": {{{steps.get_posts.response_json}}},\n  \"total_ms\": {{total_duration}}\n}",
        "content_type": "application/json",
        "status_code": 200
      }
    }
  },

