  "test17.test": {
    "id": "e2e-test17",
    "hostname": "test17.test",
    "forward_rules": [
      {
        "hostname": "test17-valid",
        "rules": [{ "path": { "prefix": "/valid" } }]
      },
      {
        "hostname": "test17-invalid",
        "rules": [{ "path": { "prefix": "/invalid" } }]
      }
    ],
    "action": {
      "type": "static",
      "status_code": 404,
      "body": "Use /valid or /invalid"
    }
  },
  "test17-valid": {
    "id": "e2e-test17-valid",
    "hostname": "test17-valid",
    "action": {
      "type": "static",
      "status_code": 200,
      "content_type": "application/json",
      "json_body": { "name": "John", "age": 30 }
    },
    "transforms": [
      {
        "type": "json_schema",
        "content_types": ["application/json"],
        "action": "validate",
        "schema": {
          "type": "object",
          "required": ["name", "age"],
          "properties": {
            "name": { "type": "string" },
            "age": { "type": "integer" }
          }
        }
      }
    ]
  },
  "test17-invalid": {
    "id": "e2e-test17-invalid",
    "hostname": "test17-invalid",
    "action": {
      "type": "static",
      "status_code": 200,
