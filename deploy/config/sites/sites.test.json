      "json_body": { "name": "John" }
    },
    "transforms": [
      {
        "type": "json_schema",
        "content_types": ["application/json"],
        "action": "validate",
        "schema": {
          "type": "object",
          "required": ["name", "age"],
          "properties": {
            "name": { "type": "string" },
            "age": { "type": "integer" }
          }
        }
      }
    ]
  },

