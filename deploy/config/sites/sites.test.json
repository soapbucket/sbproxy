    }
  },

  "test10.test": {
    "id": "e2e-test10",
    "hostname": "test10.test",
    "action": {
      "type": "orchestration",
      "parallel": true,
      "timeout": "10s",
      "steps": [
        {
          "name": "get_user",
          "callback": {
            "url": "https://jsonplaceholder.typicode.com/users/1",
            "method": "GET"
          }
        },
        {
          "name": "get_post",
          "callback": {
            "url": "https://jsonplaceholder.typicode.com/posts/1",
            "method": "GET"
          }
        }
      ],
      "response_builder": {
        "template": "{\n  \"user\": {{{steps.get_user.response_json}}},\n  \"post\": {{{steps.get_post.response_json}}}\n}",
        "content_type": "application/json",
        "status_code": 200
      }
    }
  },

