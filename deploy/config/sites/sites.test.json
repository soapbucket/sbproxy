  "test14.test": {
    "id": "e2e-test14",
    "hostname": "test14.test",
    "action": {
      "type": "static",
      "status_code": 200,
      "content_type": "application/json",
      "json_body": {
        "user_id": 123,
        "first_name": "John",
        "last_name": "Doe",
        "country_code": "UNITED_STATES"
      }
    },
    "transforms": [
      {
        "type": "lua_json",
        "content_types": ["application/json"],
        "timeout": "100ms",
        "lua_script": "function modify_json(data, ctx)\n  local result = {\n    id = data.user_id,\n    fullName = (data.first_name or '') .. ' ' .. (data.last_name or ''),\n    country = 'US'\n  }\n  return result\nend"
      }
    ]
  },

