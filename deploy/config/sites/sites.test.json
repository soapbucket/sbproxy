  "test6.test": {
    "id": "e2e-test6",
    "hostname": "test6.test",
    "action": {
      "type": "proxy",
      "url": "https://postman-echo.com",
      "strip_base_path": true,
      "shadow": {
        "upstream_url": "https://httpbin.org/anything",
        "sample_rate": 1.0,
        "fail_on_error": false,
        "timeout": "2s"
      }
    },
    "response_modifiers": [
      { "headers": { "set": { "X-Shadow-Enabled": "true" } } }
    ]
  },

  "test7.test": {
    "id": "e2e-test7",
    "hostname": "test7.test",
    "action": {
      "type": "loadbalancer",
      "disable_sticky": true,
      "targets": [
        {
          "url": "https://postman-echo.com/get?backend=1",
          "weight": 34,
          "response_modifiers": [
            { "headers": { "add": { "X-Served-By": "backend-1" } } }
          ]
        },
        {
          "url": "https://postman-echo.com/get?backend=2",
          "weight": 33,
          "response_modifiers": [
            { "headers": { "add": { "X-Served-By": "backend-2" } } }
          ]
        },
        {
          "url": "https://postman-echo.com/get?backend=3",
          "weight": 33,
          "response_modifiers": [
            { "headers": { "add": { "X-Served-By": "backend-3" } } }
          ]
        }
      ]
    }
  },

  "test8.test": {
    "id": "e2e-test8",
    "hostname": "test8.test",
    "action": {
      "type": "abtest",
      "test_name": "e2e-checkout-test",
      "cookie_name": "_ab_e2e",
      "cookie_ttl": "1d",
      "variants": [
        {
          "name": "control",
          "weight": 50,
          "action": {
            "type": "static",
            "status_code": 200,
            "content_type": "application/json",
            "json_body": { "variant": "control", "test": "checkout" }
          }
        },
        {
          "name": "treatment",
          "weight": 50,
          "action": {
            "type": "static",
            "status_code": 200,
            "content_type": "application/json",
            "json_body": { "variant": "treatment", "test": "checkout" }
          }
        }
      ]
    },
    "response_modifiers": [
      { "headers": { "set": { "X-AB-Test": "e2e-checkout-test" } } }
    ]
  },

  "test9.test": {
    "id": "e2e-test9",
