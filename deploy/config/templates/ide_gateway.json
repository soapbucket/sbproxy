{
  "_description": "IDE Gateway template - optimized for code completion tools (Cursor, Claude Code, Cline, GitHub Copilot, Zed)",
  "_usage": "Point your IDE's AI provider URL to this gateway. Supports OpenAI-compatible and Anthropic-compatible endpoints.",
  "hostname": "ide-gateway.example.com",
  "policies": [
    {
      "type": "rate_limiting",
      "requests_per_minute": 120,
      "burst_size": 20
    },
    {
      "type": "cors",
      "allowed_origins": ["*"],
      "allowed_methods": ["POST", "GET", "OPTIONS"],
      "allowed_headers": ["Authorization", "Content-Type", "X-Request-ID", "Anthropic-Version", "OpenAI-Organization"],
      "max_age_seconds": 86400
    }
  ],
  "auth": {
    "type": "api_key",
    "header": "Authorization",
    "prefix": "Bearer "
  },
  "action": {
    "type": "ai_proxy",
    "providers": [
      {
        "name": "openai",
        "type": "openai",
        "url": "https://api.openai.com/v1",
        "api_key": "${OPENAI_API_KEY}",
        "weight": 50
      },
      {
        "name": "anthropic",
        "type": "anthropic",
        "url": "https://api.anthropic.com/v1",
        "api_key": "${ANTHROPIC_API_KEY}",
        "weight": 50
      }
    ],
    "default_model": "gpt-4o",
    "routing": {
      "strategy": "fallback_chain",
      "fallback_order": ["openai", "anthropic"],
      "retry": {
        "max_attempts": 2,
        "backoff_ms": 500,
        "retry_on_status": [429, 500, 502, 503],
        "retry_on_timeout": true
      }
    },
    "cache": {
      "enabled": true,
      "similarity_threshold": 0.98,
      "ttl_seconds": 300,
      "max_entries": 5000
    },
    "budget": {
      "limits": [
        { "scope": "api_key", "max_tokens": 500000, "period": "daily" }
      ],
      "on_exceed": "log"
    },
    "session_tracking": true,
    "zero_data_retention": false,
    "log_policy": "metadata_only"
  }
}
