# sbproxy example cassette: ai-agent-alignment. Auto-generated by scripts/gen-example-tapes.py.
# Regenerate with: scripts/record-tapes.sh ai-agent-alignment
#
# CONFIG: examples/ai-agent-alignment/sb.yml

Output "docs/assets/ai-agent-alignment.gif"

Require curl

Set Shell "bash"
Set FontSize 16
Set Width 1280
Set Height 600
Set Padding 24
Set TypingSpeed 30ms
Set Theme { "name": "sbproxy", "background": "#0d0d0f", "foreground": "#e6e6e6", "cursor": "#ffb454", "selection": "#2a2a33", "black": "#1a1a1f", "red": "#ff6b6b", "green": "#a8d96a", "yellow": "#ffb454", "blue": "#7aa2f7", "magenta": "#bb9af7", "cyan": "#7dcfff", "white": "#e6e6e6", "brightBlack": "#5c5c66", "brightRed": "#ff8888", "brightGreen": "#c3f088", "brightYellow": "#ffd194", "brightBlue": "#9bb8ff", "brightMagenta": "#d4b8ff", "brightCyan": "#a4e0ff", "brightWhite": "#ffffff" }

Hide
Type `export PS1='$ '; clear`
Enter
Show

Type `curl http://127.0.0.1:8080/v1/chat/completions -H 'Host: ai.local' -H 'Content-Type: application/json' -d '{ "model": "claude-haiku-4-5", "messages": [ {"role": "user", "content": "Find news about Rust 1.96."}, {"role": "assistant", "content": null, "tool_calls": [ {"id": "t1", "function": {"name": "search", "arguments": "{\"q\": \"Rust 1.96\"}"}} ]} ] }'`
Enter
Sleep 3.5s

Type `curl http://127.0.0.1:8080/v1/chat/completions -H 'Host: ai.local' -H 'Content-Type: application/json' -d '{ "model": "claude-haiku-4-5", "messages": [ {"role": "user", "content": "Tidy up my account."}, {"role": "assistant", "content": null, "tool_calls": [ {"id": "t1", "function": {"name": "delete_account", "arguments": "{}"}} ]} ] }'`
Enter
Sleep 3.5s

