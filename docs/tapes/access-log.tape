# sbproxy example cassette: access-log. Auto-generated by scripts/gen-example-tapes.py.
# Regenerate with: scripts/record-tapes.sh access-log
#
# CONFIG: examples/access-log/sb.yml

Output "docs/assets/access-log.gif"

Require curl

Set Shell "bash"
Set FontSize 16
Set Width 1280
Set Height 600
Set Padding 24
Set TypingSpeed 30ms
Set Theme { "name": "sbproxy", "background": "#0d0d0f", "foreground": "#e6e6e6", "cursor": "#ffb454", "selection": "#2a2a33", "black": "#1a1a1f", "red": "#ff6b6b", "green": "#a8d96a", "yellow": "#ffb454", "blue": "#7aa2f7", "magenta": "#bb9af7", "cyan": "#7dcfff", "white": "#e6e6e6", "brightBlack": "#5c5c66", "brightRed": "#ff8888", "brightGreen": "#c3f088", "brightYellow": "#ffd194", "brightBlue": "#9bb8ff", "brightMagenta": "#d4b8ff", "brightCyan": "#a4e0ff", "brightWhite": "#ffffff" }

Hide
Type `export PS1='$ '; clear`
Enter
Show

Type `curl -s -H 'Host: api.local' http://127.0.0.1:8080/anything | head -c 80`
Enter
Sleep 1.6s

Type `curl -s -H 'Host: api.local' -X POST http://127.0.0.1:8080/anything`
Enter
Sleep 1.6s

