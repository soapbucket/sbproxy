Output "docs/assets/a2a-protocol.gif"

Require curl

Set Shell "bash"
Set FontSize 16
Set Width 1280
Set Height 600
Set Padding 24
Set TypingSpeed 30ms
Set Theme { "name": "sbproxy", "background": "#0d0d0f", "foreground": "#e6e6e6", "cursor": "#ffb454", "selection": "#2a2a33", "black": "#1a1a1f", "red": "#ff6b6b", "green": "#a8d96a", "yellow": "#ffb454", "blue": "#7aa2f7", "magenta": "#bb9af7", "cyan": "#7dcfff", "white": "#e6e6e6", "brightBlack": "#5c5c66", "brightRed": "#ff8888", "brightGreen": "#c3f088", "brightYellow": "#ffd194", "brightBlue": "#9bb8ff", "brightMagenta": "#d4b8ff", "brightCyan": "#a4e0ff", "brightWhite": "#ffffff" }

Hide
Type `export PS1='$ '; clear`
Enter
Show

Type `curl -i -H 'Host: a2a.local' -H 'Content-Type: application/a2a+json' -H 'X-A2A-Caller-Agent-Id: agent:caller' -H 'X-A2A-Callee-Agent-Id: agent:openai:gpt-5' -H 'X-A2A-Task-Id: task-1' -H 'X-A2A-Chain-Depth: 1' http://127.0.0.1:8080/agents/invoke`
Enter
Sleep 1.6s

Type `curl -i -H 'Host: a2a.local' -H 'Content-Type: application/a2a+json' -H 'X-A2A-Caller-Agent-Id: agent:caller' -H 'X-A2A-Callee-Agent-Id: agent:openai:gpt-5' -H 'X-A2A-Chain-Depth: 7' http://127.0.0.1:8080/agents/invoke`
Enter
Sleep 1.6s

